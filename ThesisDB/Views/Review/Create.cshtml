    <input type="hidden" asp-for="ThesisId" />

    <div class="row">
        <div class="col-md-12 mb-3">
            <label asp-for="Summary" class="control-label fw-bold"></label>
            <textarea asp-for="Summary" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Summary" class="text-danger"></span>
        </div>
        <div class="col-md-12 mb-3">
            <label asp-for="Strengths" class="control-label fw-bold"></label>
            <textarea asp-for="Strengths" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Strengths" class="text-danger"></span>
        </div>
        <div class="col-md-12 mb-3">
            <label asp-for="Weaknesses" class="control-label fw-bold"></label>
            <textarea asp-for="Weaknesses" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Weaknesses" class="text-danger"></span>
        </div>
        <div class="col-md-12 mb-3">
            <label asp-for="Evaluation" class="control-label fw-bold"></label>
            <textarea asp-for="Evaluation" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Evaluation" class="text-danger"></span>
        </div>
    </div>

