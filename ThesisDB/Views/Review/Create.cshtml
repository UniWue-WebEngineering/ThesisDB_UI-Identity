        </tbody>
        <tfoot class="table-secondary">
            <tr>
                <td><strong>Notenvorschlag</strong></td>
                <td id="suggestedGrade" class="text-center fw-bold fs-5"></td>
                <td><span id="weightSumBadge" class="badge"></span></td>
            </tr>
        </tfoot>
    </table>

    <div class="row mt-4">
        <div class="col-md-4 mb-3">
            <label asp-for="Grade" class="control-label fw-bold"></label>
            <select asp-for="Grade" class="form-select" asp-items="ViewBag.GradeList"></select>
            <span asp-validation-for="Grade" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-4 mb-5">
        <input type="submit" value="Speichern" class="btn btn-primary" />
        <a asp-controller="Thesis" asp-action="Index" class="btn btn-secondary">Abbrechen</a>
    </div>
</form>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const starContainers = document.querySelectorAll('.star-rating');

            function updateStars(container, note) {
                const stars = container.querySelectorAll('.star-icon');
                let filledCount = 0;
                if (!isNaN(note) && note >= 1 && note <= 5) {
                    filledCount = 6 - note;
                }

                stars.forEach((star, index) => {
                    star.classList.remove('bi-star', 'bi-star-fill', 'text-secondary', 'text-dark');
                    if (filledCount === 0) {
                        star.classList.add('bi-star', 'text-secondary');
                    } else {
                        if (index < filledCount) {
                            star.classList.add('bi-star-fill', 'text-dark');
                        } else {
                            star.classList.add('bi-star', 'text-dark');
                        }
                    }
                });
            }

            starContainers.forEach(container => {
                const targetSelector = container.getAttribute('data-target');
                const hiddenInput = document.querySelector(targetSelector);

                const initialNote = parseInt(hiddenInput.value);
                updateStars(container, initialNote);

                const stars = container.querySelectorAll('.star-icon');
                stars.forEach(star => {
                    star.addEventListener('click', function () {
                        const note = parseInt(this.getAttribute('data-note'));
                        hiddenInput.value = note;
                        updateStars(container, note);
                        calculateSuggestion();
                    });
                });
            });

            const weightInputs = document.querySelectorAll('.weight-input');
            weightInputs.forEach(input => {
                input.addEventListener('input', calculateSuggestion);
                input.addEventListener('change', calculateSuggestion);
            });

            function calculateSuggestion() {
                let allSet = true;
                let sumWeights = 0;
                let weightedSum = 0;

                const partials = [
                    { valId: '#ContentVal', wtId: '#ContentWt' },
                    { valId: '#LayoutVal', wtId: '#LayoutWt' },
                    { valId: '#StructureVal', wtId: '#StructureWt' },
                    { valId: '#StyleVal', wtId: '#StyleWt' },
                    { valId: '#LiteratureVal', wtId: '#LiteratureWt' },
                    { valId: '#DifficultyVal', wtId: '#DifficultyWt' },
                    { valId: '#NoveltyVal', wtId: '#NoveltyWt' },
                    { valId: '#RichnessVal', wtId: '#RichnessWt' }
                ];

                partials.forEach(p => {
                    const valInput = document.querySelector(p.valId);
                    const wtInput = document.querySelector(p.wtId);

                    if (!valInput || !wtInput) {
                        allSet = false;
                        return;
                    }

                    const val = parseInt(valInput.value);
                    const wt = parseFloat(wtInput.value);

                    if (isNaN(val) || val < 1 || val > 5) {
                        allSet = false;
                    }
                    if (isNaN(wt)) {
                        allSet = false;
                    } else {
                        sumWeights += wt;
                    }

                    if (!isNaN(val) && val >= 1 && val <= 5 && !isNaN(wt)) {
                        weightedSum += val * wt;
                    }
                });

                const badge = document.getElementById('weightSumBadge');
                if (badge) {
                    badge.textContent = sumWeights + ' %';
                    badge.classList.remove('bg-success', 'bg-warning', 'text-dark');
                    if (sumWeights === 100) {
                        badge.classList.add('bg-success');
                    } else {
                        badge.classList.add('bg-warning', 'text-dark');
                    }
                }

                const suggestionCell = document.getElementById('suggestedGrade');
                if (suggestionCell) {
                    if (allSet && sumWeights > 0) {
                        const suggestion = weightedSum / sumWeights;
                        suggestionCell.textContent = suggestion.toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                    } else {
                        suggestionCell.textContent = '';
                    }
                }
            }

            calculateSuggestion();
        });
    </script>
}