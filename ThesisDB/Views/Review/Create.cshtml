@model ThesisDB.Models.Review

@{
    ViewData["Title"] = "Neues Gutachten";
}

<h1>Neues Gutachten</h1>
<h2 class="h4 text-muted">@ViewBag.ThesisTitle</h2>
<hr />
<form asp-action="Create">
