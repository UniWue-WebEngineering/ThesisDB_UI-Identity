                        <i class="bi bi-star text-secondary star-icon" data-note="4" data-stars="2" style="cursor: pointer; font-size: 1.5rem;"></i>
                        <i class="bi bi-star text-secondary star-icon" data-note="3" data-stars="3" style="cursor: pointer; font-size: 1.5rem;"></i>
                        <i class="bi bi-star text-secondary star-icon" data-note="2" data-stars="4" style="cursor: pointer; font-size: 1.5rem;"></i>
                        <i class="bi bi-star text-secondary star-icon" data-note="1" data-stars="5" style="cursor: pointer; font-size: 1.5rem;"></i>
