@model ThesisDB.Models.Thesis

@{
    ViewData["Title"] = "Thema bearbeiten";
}

<h1>Thema bearbeiten</h1>
<hr />
<div class="row">
    <div class="col-md-12">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Title" class="control-label fw-bold"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="control-label fw-bold"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Status" class="control-label fw-bold"></label>
                    <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<ThesisDB.Models.Thesis.ThesisStatus>()"></select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Type" class="control-label fw-bold"></label>
                    <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<ThesisDB.Models.Thesis.ThesisType>()"></select>
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="StartDate" class="control-label fw-bold"></label>
                    <input asp-for="StartDate" class="form-control" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="EndDate" class="control-label fw-bold"></label>
                    <input asp-for="EndDate" class="form-control" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="ProgrammeId" class="control-label fw-bold">Studiengang</label>
                    <select asp-for="ProgrammeId" class="form-select" asp-items="ViewBag.ProgrammeId"></select>
                    <span asp-validation-for="ProgrammeId" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="StudentId" class="control-label fw-bold">Student/-in</label>
                    <div class="input-group">
                        <input type="hidden" asp-for="StudentId" id="StudentIdHidden" />
                        <input type="text" class="form-control" id="StudentNameDisplay" readonly value="@(Model.Student != null ? $"{Model.Student.FirstName} {Model.Student.LastName} ({Model.Student.MatriculationNumber})" : "-- Nicht zugewiesen --")" />
                        <button class="btn btn-secondary" type="button" data-bs-toggle="modal" data-bs-target="#studentModal" title="Student auswählen/anlegen">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn btn-danger" type="button" id="btnRemoveStudent" title="Zuordnung entfernen">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                    <span asp-validation-for="StudentId" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="SupervisorId" class="control-label fw-bold">Betreuer/-in</label>
                    <select asp-for="SupervisorId" class="form-select" asp-items="ViewBag.SupervisorId"></select>
                    <span asp-validation-for="SupervisorId" class="text-danger"></span>
                </div>
            </div>
            <div class="mb-3">
                <input type="submit" value="Speichern" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Zurück zur Liste</a>
</div>

<!-- Modal für Student -->
<div class="modal fade" id="studentModal" tabindex="-1" aria-labelledby="studentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="studentModalLabel">Student auswählen oder anlegen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs" id="studentTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="search-tab" data-bs-toggle="tab" data-bs-target="#search-tab-pane" type="button" role="tab" aria-controls="search-tab-pane" aria-selected="true">Suchen</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="create-tab" data-bs-toggle="tab" data-bs-target="#create-tab-pane" type="button" role="tab" aria-controls="create-tab-pane" aria-selected="false">Neu anlegen</button>
                    </li>
                </ul>
                <div class="tab-content mt-3" id="studentTabsContent">
                    <!-- Suchen Tab -->
                    <div class="tab-pane fade show active" id="search-tab-pane" role="tabpanel" aria-labelledby="search-tab" tabindex="0">
                        <div class="mb-3">
                            <input type="text" id="searchInput" class="form-control" placeholder="Vorname oder Nachname suchen (mind. 3 Zeichen)" />
                        </div>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover" id="searchResultsTable" style="display:none;">
                                <thead>
                                    <tr>
                                        <th>Vorname</th>
                                        <th>Nachname</th>
                                        <th>Matrikelnummer</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
                            <div id="searchNoResults" class="alert alert-info" style="display:none;">Keine Ergebnisse gefunden.</div>
                        </div>
                    </div>
                    <!-- Neu anlegen Tab -->
                    <div class="tab-pane fade" id="create-tab-pane" role="tabpanel" aria-labelledby="create-tab" tabindex="0">
                        <form id="createStudentForm">
                            <div class="mb-3">
                                <label for="createFirstName" class="form-label">Vorname</label>
                                <input type="text" class="form-control" id="createFirstName" required />
                            </div>
                            <div class="mb-3">
                                <label for="createLastName" class="form-label">Nachname</label>
                                <input type="text" class="form-control" id="createLastName" required />
                            </div>
                            <div class="mb-3">
                                <label for="createEmail" class="form-label">E-Mail</label>
                                <input type="email" class="form-control" id="createEmail" required />
                            </div>
                            <div class="mb-3">
                                <label for="createMatriculationNumber" class="form-label">Matrikelnummer</label>
                                <input type="text" class="form-control" id="createMatriculationNumber" required />
                            </div>
                            <button type="submit" class="btn btn-primary">Speichern</button>
                            <div id="createError" class="alert alert-danger mt-3" style="display:none;"></div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const btnRemoveStudent = document.getElementById("btnRemoveStudent");
            const studentIdHidden = document.getElementById("StudentIdHidden");
            const studentNameDisplay = document.getElementById("StudentNameDisplay");
            const searchInput = document.getElementById("searchInput");
            const searchResultsTable = document.getElementById("searchResultsTable");
            const searchResultsBody = searchResultsTable.querySelector("tbody");
            const searchNoResults = document.getElementById("searchNoResults");
            const createStudentForm = document.getElementById("createStudentForm");
            const createError = document.getElementById("createError");
            
            const studentModalEl = document.getElementById('studentModal');
            const studentModal = new bootstrap.Modal(studentModalEl);

            btnRemoveStudent.addEventListener("click", function () {
                studentIdHidden.value = "";
                studentNameDisplay.value = "-- Nicht zugewiesen --";
            });

            // Suchen Funktionalität
            let searchTimeout = null;
            searchInput.addEventListener("input", function () {
                clearTimeout(searchTimeout);
                const query = this.value.trim();
                
                if (query.length < 3) {
                    searchResultsTable.style.display = 'none';
                    searchNoResults.style.display = 'none';
                    return;
                }

                searchTimeout = setTimeout(() => {
                    fetch('/api/StudentsApi/search?q=' + encodeURIComponent(query))
                        .then(response => response.json())
                        .then(data => {
                            searchResultsBody.innerHTML = '';
                            if (data && data.length > 0) {
                                data.forEach(student => {
                                    const tr = document.createElement("tr");
                                    tr.innerHTML = `
                                        <td>${student.firstName}</td>
                                        <td>${student.lastName}</td>
                                        <td>${student.matriculationNumber}</td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-sm btn-success btn-select-student" data-id="${student.id}" data-name="${student.displayName}">Auswählen</button>
                                        </td>
                                    `;
                                    searchResultsBody.appendChild(tr);
                                });
                                searchResultsTable.style.display = 'table';
                                searchNoResults.style.display = 'none';
                                
                                document.querySelectorAll('.btn-select-student').forEach(btn => {
                                    btn.addEventListener('click', function() {
                                        studentIdHidden.value = this.getAttribute('data-id');
                                        studentNameDisplay.value = this.getAttribute('data-name');
                                        studentModal.hide();
                                    });
                                });
                            } else {
                                searchResultsTable.style.display = 'none';
                                searchNoResults.style.display = 'block';
                            }
                        })
                        .catch(err => console.error("Search error:", err));
                }, 300);
            });

            // Neu anlegen Funktionalität
            createStudentForm.addEventListener("submit", function (e) {
                e.preventDefault();
                createError.style.display = 'none';
                
                const data = {
                    FirstName: document.getElementById("createFirstName").value.trim(),
                    LastName: document.getElementById("createLastName").value.trim(),
                    Email: document.getElementById("createEmail").value.trim(),
                    MatriculationNumber: document.getElementById("createMatriculationNumber").value.trim()
                };

                fetch('/api/StudentsApi', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(data)
                })
                .then(async response => {
                    if (response.ok) {
                        return response.json();
                    } else {
                        const errText = await response.text();
                        throw new Error(errText);
                    }
                })
                .then(student => {
                    studentIdHidden.value = student.id;
                    studentNameDisplay.value = student.displayName;
                    studentModal.hide();
                    createStudentForm.reset();
                })
                .catch(err => {
                    console.error("Create error:", err);
                    createError.textContent = "Fehler beim Anlegen: " + err.message;
                    createError.style.display = 'block';
                });
            });
            
            // Modal beim Schließen resetten
            studentModalEl.addEventListener('hidden.bs.modal', function () {
                searchInput.value = '';
                searchResultsTable.style.display = 'none';
                searchNoResults.style.display = 'none';
                searchResultsBody.innerHTML = '';
                createStudentForm.reset();
                createError.style.display = 'none';
                // Zurück zum Search Tab
                const searchTab = new bootstrap.Tab(document.querySelector('#search-tab'));
                searchTab.show();
            });
        });
    </script>
}